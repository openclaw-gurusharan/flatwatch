FLATWATCH_DATABASE_PATH=./data/flatwatch.db
FRONTEND_URL=http://127.0.0.1:43105
IDENTITY_URL=https://aadharcha.in

# Comma-separated frontend origins allowed to call the backend.
CORS_ORIGINS=http://127.0.0.1:43100,http://127.0.0.1:43102,http://127.0.0.1:43103,http://127.0.0.1:43105,https://aadharcha.in,https://ondcbuyer.aadharcha.in,https://ondcseller.aadharcha.in,https://flatwatch.aadharcha.in

CLAUDE_AGENT_AUTH_MODE=local_cli
CLAUDE_AGENT_ALLOW_LOCAL_CLI_AUTH=true

# Deployed browser origins that are allowed to use Claude Code CLI auth via this backend.
CLAUDE_AGENT_ALLOWED_ORIGINS=https://flatwatch.aadharcha.in
CLAUDE_AGENT_MODEL=claude-haiku-4-5-20251001
CLAUDE_CODE_EXECUTABLE=
