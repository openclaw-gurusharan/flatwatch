# Production environment variables for FlatWatch Frontend
# Copy this to .env.production and fill in values

# API URL (e.g., https://flatwatch-api.onrender.com)
NEXT_PUBLIC_API_URL=your_api_url_here

# Trust API URL (e.g., https://identity-aadhar-gateway.onrender.com)
NEXT_PUBLIC_TRUST_API_URL=your_trust_api_url_here

# SSO Identity Provider URL
NEXT_PUBLIC_IDENTITY_WEB_URL=https://aadharcha.in
