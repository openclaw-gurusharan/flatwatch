{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["sin1"],
  "env": {
    "NEXT_PUBLIC_TRUST_API_URL": "https://identity-aadhar-gateway.onrender.com",
    "NEXT_PUBLIC_IDENTITY_WEB_URL": "https://aadharcha.in"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://flatwatch-api.onrender.com/api/:path*"
    }
  ]
}
