# Local development environment variables for FlatWatch Frontend
# Copy this to .env.local for local development

# API URL - Local backend
NEXT_PUBLIC_API_URL=http://127.0.0.1:43104

# Trust API - AadhaarChain gateway
NEXT_PUBLIC_TRUST_API_URL=http://127.0.0.1:43101

# SSO Identity Provider URL - Local development
NEXT_PUBLIC_IDENTITY_WEB_URL=http://127.0.0.1:43100
